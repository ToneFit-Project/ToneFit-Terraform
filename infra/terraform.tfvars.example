# ============================================================
# ToneFit — Terraform 변수 예시 파일
# 이 파일을 복사해서 terraform.tfvars로 만든 뒤 실제 값을 입력하세요.
# terraform.tfvars는 절대 git에 커밋하지 마세요.
#
# [이 파일의 범위]
# 인프라 리소스 생성에 필요한 값만 관리합니다.
#
# [이 파일에 넣지 않는 것 — AWS Secrets Manager로 별도 관리]
# GEMINI_API_KEY, JWT_SECRET, GOOGLE_CLIENT_ID/SECRET 등
# 앱 레벨 시크릿은 terraform apply 후 AWS 콘솔 또는 CLI로 직접 입력합니다.
# ============================================================

# ------------------------------------------------------------
# 프로젝트 공통
# ------------------------------------------------------------
project     = "tonefit"
environment = "prod"               # prod / dev
aws_region  = "ap-northeast-2"

# ------------------------------------------------------------
# 네트워크 (변경 불필요 — 기본값 사용 권장)
# ------------------------------------------------------------
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]   # 2a, 2c
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]  # 2a, 2c

# ------------------------------------------------------------
# EC2
# ------------------------------------------------------------
ec2_instance_type = "t3.small"
ec2_key_pair_name = "tonefit-key"       # Phase 0에서 생성한 키페어 이름

# SSH 접속을 허용할 개발자 IP 목록
# 확인 방법: curl ifconfig.me
# 여러 명이면 추가 가능: ["1.2.3.4/32", "5.6.7.8/32"]
allowed_ssh_cidrs = ["YOUR_IP/32"]

# ------------------------------------------------------------
# RDS (PostgreSQL)
# ------------------------------------------------------------
rds_instance_class    = "db.t3.micro"
rds_engine_version    = "16"
rds_db_name           = "tonefit"
rds_username          = "tonefit_admin"  # 마스터 계정명
rds_password          = "CHANGE_ME"      # 20자 이상, 특수문자 포함 권장
                                          # 생성 예: openssl rand -base64 20
rds_allocated_storage = 20               # GB

# ------------------------------------------------------------
# 도메인 (도메인 구매 전까지 빈 값으로 두세요)
# ------------------------------------------------------------
domain_name   = ""   # 예: tonefit.kr  (CloudFront 프론트엔드 루트 도메인)
api_subdomain = ""   # 예: api.tonefit.kr  (EC2 백엔드 API)

# ------------------------------------------------------------
# 태그 (AWS 콘솔에서 리소스 식별용)
# ------------------------------------------------------------
tags = {
  Project     = "tonefit"
  Environment = "prod"
  ManagedBy   = "terraform"
}
